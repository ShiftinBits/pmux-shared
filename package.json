{
  "name": "@pocketmux/shared",
  "version": "0.1.0",
  "description": "Shared TypeScript types for the PocketMux wire protocol and signaling messages",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "npm run clean && npm run build",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "fixtures": "tsx src/__tests__/fixtures/generate-fixtures.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3"
  }
}
